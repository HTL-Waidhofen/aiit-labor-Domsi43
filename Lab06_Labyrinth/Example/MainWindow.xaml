<Window x:Class="Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="450"
        KeyDown="Window_KeyDown"
        Focusable="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Left" Margin="8">
            <TextBlock Text="LebakasSömmen:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock x:Name="GoodieCounter" Text="0" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="Leben:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock x:Name="PointsCounter" Text="0" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

       
        <Canvas x:Name="Spielfeld" Background="White" Width="400" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1"/>
    
        <Grid x:Name="GameOverOverlay" Background="#CC000000" Visibility="Collapsed">
            <TextBlock Text="GAME OVER" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="WinOverlay" Background="#CC000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
                <TextBlock Text="YOU WIN!" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock x:Name="WinDetails" Text="" Foreground="White" FontSize="20" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>